// Resumo Semanal: novos leads, propostas enviadas, pagamentos previstos pra semana e contratos parados
// em Rascunho/Enviado — um retrato rápido pra quem não abriu o app durante a semana.
function enviarResumoSemanalPorEmail_() {
  try {
    if (obterConfigValor_('resumoSemanalEmailAtivo', 'nao') !== 'sim') return;
    var destinatarios = obterConfigValor_('emailDestinatariosAlertas', '') || obterConfigValor_('emailEmpresa', '');
    if (!destinatarios) { logErro('enviarResumoSemanalPorEmail_', new Error('Sem destinatários configurados.')); return; }
    var remetenteNome = obterConfigValor_('emailRemetenteNome', '') || obterConfigValor_('nomeFantasia', '') || 'Aranuz';

    var hoje = new Date();
    var seteDiasAtras = new Date(hoje.getTime() - 7 * 24 * 60 * 60 * 1000);
    var seteDiasNaFrente = new Date(hoje.getTime() + 7 * 24 * 60 * 60 * 1000);

    var leads = lerOportunidades();
    var novosLeads = leads.filter(function(l){ var d = new Date(l.data_entrada); return l.data_entrada && d >= seteDiasAtras && d <= hoje; });

    var orcamentos = lerOrcamentos();
    var propostasEnviadas = orcamentos.filter(function(o){ var d = new Date(o.data); return o.data && d >= seteDiasAtras && d <= hoje; });

    var financeiro = lerFinanceiro();
    var pagamentosPrevistos = financeiro.filter(function(f){
      if (String(f.status).toLowerCase() === 'pago') return false;
      var d = new Date(f.data);
      return f.data && d >= hoje && d <= seteDiasNaFrente;
    });
    var totalAPagarSemana = 0, totalAReceberSemana = 0;
    pagamentosPrevistos.forEach(function(f){ if (f.tipoMovimento === 'saida') totalAPagarSemana += (f.valor||0); else totalAReceberSemana += (f.valor||0); });

    var contratos = lerContratos();
    var contratosParados = contratos.filter(function(c){ return c.status === 'Rascunho' || c.status === 'Enviado'; });

    var corpo = '<h2 style="margin:0 0 12px;">📋 Resumo Semanal — Aranuz</h2>'
      + '<p style="color:#666; font-size:12px; margin-top:0;">Semana de ' + Utilities.formatDate(seteDiasAtras, Session.getScriptTimeZone(), 'dd/MM') + ' a ' + Utilities.formatDate(hoje, Session.getScriptTimeZone(), 'dd/MM/yyyy') + '</p>'
      + '<ul style="font-size:13px; line-height:1.8;">'
      + '<li><strong>' + novosLeads.length + '</strong> lead(s) novo(s) esta semana</li>'
      + '<li><strong>' + propostasEnviadas.length + '</strong> proposta(s)/orçamento(s) lançado(s) esta semana</li>'
