      if (db.objetivosMes) gravarGenerico(SHEET_OBJMES, OBJMES_COLS, db.objetivosMes);
      if (db.catalogoLocacao) gravarCatalogoLocacao(db.catalogoLocacao);
      if (db.catalogoServicos) gravarCatalogoServicos(db.catalogoServicos);
      if (db.locacoes) gravarLocacoes(db.locacoes);
      if (db.locacoesItens) gravarLocacoesItens(db.locacoesItens);
      if (db.orcamentoItens) gravarOrcamentoItens(db.orcamentoItens);
      if (db.propostaServicoItens) gravarPropostaServicoItens(db.propostaServicoItens);
      if (db.npsRespostas) gravarNps(db.npsRespostas);
      if (db.contratoTemplates) gravarTemplatesContrato(db.contratoTemplates);
      if (db.contratos) gravarContratos(db.contratos);
      if (db.contratoAnexoItens) gravarContratoAnexoItens(db.contratoAnexoItens);
      if (db.configuracoes) gravarConfiguracoes(db.configuracoes); // V158: bugfix — nunca era salvo antes
      // V2.50: Marketing (V2.48, corrigido aqui — faltava por completo) + Gestão de Projetos Culturais
      // Fase 1 (V2.50).
      if (db.campanhas) gravarGenerico(SHEET_CAMPANHAS, CAMPANHAS_COLS, db.campanhas);
      if (db.calendarioConteudo) gravarGenerico(SHEET_CALCONTEUDO, CALCONTEUDO_COLS, db.calendarioConteudo);
      if (db.portfolio) gravarGenerico(SHEET_PORTFOLIO, PORTFOLIO_COLS, db.portfolio);
      if (db.orgaosFomento) gravarGenerico(SHEET_ORGAOS, ORGAOS_COLS, db.orgaosFomento);
      if (db.projetosCulturais) gravarGenerico(SHEET_PROJCULT, PROJCULT_COLS, db.projetosCulturais);
    } finally {
      if (lockOk) { try { lock.releaseLock(); } catch (releaseErr) {} }
    }
    return json({ status: "sucesso" });
  } catch (error) { logErro('doPost', error); return json({ status: "erro", detalhe: error.toString() }); }
