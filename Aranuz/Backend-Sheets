// Aplica (ou reaplica) a legenda em todas as abas de listaTabelasPrincipais_() que tiverem uma entrada
// em LEGENDA_COLUNAS_. Abas/colunas sem entrada correspondente são ignoradas silenciosamente (nunca
// derruba a função inteira por causa de uma coluna nova sem nota ainda).
function aplicarLegendaColunas() {
  listaTabelasPrincipais_().forEach(function(par) {
    var nomeAba = par[0], colunas = par[1];
    var legenda = LEGENDA_COLUNAS_[nomeAba];
    if (!legenda) return;
    try {
      var aba = obterAba(nomeAba, colunas);
      var ultimaColuna = aba.getLastColumn();
      if (ultimaColuna === 0) return;
      var header = aba.getRange(1, 1, 1, ultimaColuna).getValues()[0];
      header.forEach(function(nomeCol, idx) {
        var texto = legenda[String(nomeCol).trim()];
        if (texto) aba.getRange(1, idx + 1).setNote(texto);
      });
    } catch (e) { Logger.log('Não foi possível aplicar legenda na aba ' + nomeAba + ': ' + e); }
  });
  Logger.log('Legenda de colunas aplicada (Range.setNote) em todas as abas configuradas.');
}

// ====== V206 — Bloco 6: onEdit (gatilho SIMPLES) — correção do "bug de sincronização" ======
// Antes desta versão, uma edição feita DIRETO na planilha (fora do app, ex: corrigir um valor na mão)
// não atualizava a coluna de timestamp da linha (updatedAt/atualizadoEm, dependendo da aba). Na hora de
// decidir qual versão de um registro é a mais recente (ver mergeCollection() no front-end, que compara
// esse timestamp), a edição manual podia "perder" silenciosamente pra uma cópia desatualizada vinda de
// outro dispositivo, porque pro app os dois lados pareciam igualmente "antigos".
//
// onEdit(e) é um GATILHO SIMPLES — uma função com esse nome exato roda automaticamente sempre que
// alguém edita uma célula na interface do Google Sheets, sem precisar rodar ScriptApp.newTrigger() nem
// autorizar nada de novo (basta colar este código). Só detecta edição feita na própria tela do Sheets —
// não pega edição feita por fora, via alguma integração/API externa (bem incomum no uso normal do app).
//
// LIMITE CONHECIDO (decidido junto com o Bloco 6, ciente da troca): isso resolve bem o cenário relatado
// — edição manual sendo esquecida e sobrescrita depois — mas não é 100% à prova de tudo em teoria: se
// dois dispositivos salvarem quase ao mesmo tempo, ainda existe uma janela pequena de risco, porque cada
// salvamento do app reescreve a aba inteira de uma vez (sem comparar linha por linha no servidor). Uma
// proteção mais completa exigiria mudar também COMO o app salva — combinamos deixar isso pra um bloco
// futuro, só se algum problema real aparecer na prática.
//
// A coluna de timestamp de cada aba é descoberta automaticamente a partir de listaTabelasPrincipais_()
// (não precisa manter uma lista separada, nem mexer aqui se uma coluna nova entrar no futuro). Abas sem
// nenhuma coluna updatedAt/atualizadoEm (ex: tabelas de itens vinculados a um registro pai, como
// Locações - Itens, Orçamentos - Itens, Contrato - Itens) são ignoradas de propósito — normalmente são
// reescritas junto com o registro pai; edição direta avulsa nelas não é um fluxo esperado.
function onEdit(e) {
  try {
    if (!e || !e.range) return;
    var sheet = e.range.getSheet();
    var colTimestamp = _colunaTimestampDaAba_(sheet.getName());
    if (!colTimestamp) return;

    var ultimaColuna = sheet.getLastColumn();
    if (ultimaColuna === 0) return;
    var header = sheet.getRange(1, 1, 1, ultimaColuna).getValues()[0].map(function(h) { return String(h).trim(); });
    var idxTimestamp = header.indexOf(colTimestamp);
    if (idxTimestamp === -1) return;
    var colTimestamp1 = idxTimestamp + 1; // 1-indexado

    var range = e.range;
    if (range.getRow() === 1 && range.getNumRows() === 1) return; // só cabeçalho editado

    // Se a própria edição foi só na coluna de timestamp (uma única célula), não faz nada — evita
    // remarcar por cima de algo que acabou de ser tocado, e evita qualquer ciclo.
    if (range.getNumColumns() === 1 && range.getColumn() === colTimestamp1) return;

    var primeiraLinha = Math.max(range.getRow(), 2); // nunca mexe na linha de cabeçalho
    var numLinhas = range.getRow() + range.getNumRows() - primeiraLinha;
    if (numLinhas <= 0) return;

    var agora = Date.now();
    var valoresLinhas = sheet.getRange(primeiraLinha, 1, numLinhas, ultimaColuna).getValues();
    for (var i = 0; i < valoresLinhas.length; i++) {
      if (valoresLinhas[i].join('').trim() === '') continue; // linha em branco (ex: sobrou de um arrastar/colar maior que os dados)
      sheet.getRange(primeiraLinha + i, colTimestamp1).setValue(agora);
    }
  } catch (err) {
    try { logErro('onEdit', err); } catch (e2) {}
  }
}
function _colunaTimestampDaAba_(nomeAba) {
  var tabelas = listaTabelasPrincipais_();
  for (var i = 0; i < tabelas.length; i++) {
    if (tabelas[i][0] !== nomeAba) continue;
    var colunas = tabelas[i][1];
    if (colunas.indexOf('updatedAt') !== -1) return 'updatedAt';
