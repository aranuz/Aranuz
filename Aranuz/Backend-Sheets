// automaticamente na primeira vez que alguém salva uma exportação (manual ou automática) no Drive.
// V2.93 — 11/07/2026: troca de marca (M-Hub -> Maram Workspace). Pasta nova passou a se chamar
// "Exportações Maram", mas quem já tinha a pasta antiga ("Exportações M-Hub") continuou usando ela
// normalmente — só criava a nova se NENHUMA das duas já existisse. Evita duplicar pasta e perder o
// histórico de exportações antigas só por causa do nome ter mudado.
// V2.94 — 12/07/2026: segunda troca de marca (Maram Workspace -> Aranuz). Pasta nova passa a se chamar
// "Exportações Aranuz"; quem já tinha "Exportações Maram" ou a ainda mais antiga "Exportações M-Hub"
// continua usando a que já existir, sem duplicar nem perder histórico — só cria a pasta nova (Aranuz)
// se NENHUMA das três já existir.
function obterOuCriarPastaExportacoes_() {
  var planilha = SpreadsheetApp.getActiveSpreadsheet();
  var arquivoAtual = DriveApp.getFileById(planilha.getId());
  var pastaPai = arquivoAtual.getParents().hasNext() ? arquivoAtual.getParents().next() : DriveApp.getRootFolder();
  var nomePasta = "Exportações Aranuz";
  var nomePastaMaram = "Exportações Maram";
  var nomePastaMHub = "Exportações M-Hub";
  var it = pastaPai.getFoldersByName(nomePasta);
  if (it.hasNext()) return it.next();
  var itMaram = pastaPai.getFoldersByName(nomePastaMaram);
  if (itMaram.hasNext()) return itMaram.next();
  var itMHub = pastaPai.getFoldersByName(nomePastaMHub);
  if (itMHub.hasNext()) return itMHub.next();
  return pastaPai.createFolder(nomePasta);
}
