// Abre a planilha de origem indicada pelo usuário (aceita tanto o link completo quanto só o ID) e
// devolve uma CÓPIA descartável dela, no mesmo Drive. Nunca operamos no arquivo original do usuário —
// só na cópia — porque os leitores existentes (ver comentário de IMPORT_ORIGEM_SS_ acima) têm efeitos
// colaterais de gravação (completar "id" faltante, adicionar coluna que falta etc.) que são desejáveis
// na operação normal do app, mas que mutariam o backup do usuário se aplicados direto nele.
function abrirCopiaTemporariaDeOrigem_(origemUrlOuId) {
  var origemUrlOuIdLimpo = String(origemUrlOuId || "").trim();
  if (!origemUrlOuIdLimpo) throw new Error("Informe o link ou o ID da planilha de backup.");
  var origem;
  try {
    origem = (origemUrlOuIdLimpo.indexOf("http") === 0)
      ? SpreadsheetApp.openByUrl(origemUrlOuIdLimpo)
      : SpreadsheetApp.openById(origemUrlOuIdLimpo);
  } catch (e) {
    throw new Error("Não consegui abrir essa planilha. Confira se o link/ID está correto e se esta conta do Google tem acesso a ela. Detalhe técnico: " + e.message);
  }
  var nomeTemp = "[Aranuz] Cópia temporária de importação — " + new Date().toLocaleString("pt-BR");
  return origem.copy(nomeTemp);
}

