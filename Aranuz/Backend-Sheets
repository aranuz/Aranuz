// V160: gatilho diário (idempotente, mesmo padrão do backup) que verifica se há uma Exportação
// Automática configurada (Configurações do App) e, se a frequência bater com o dia de hoje, gera a
// cópia da seção escolhida na pasta "Exportações Aranuz" do Drive — sem precisar abrir o app.
function garantirTriggerExportacaoAutomatica() {
  const jaExiste = ScriptApp.getProjectTriggers().some(function(t) {
    return t.getHandlerFunction() === 'executarExportacaoAutomatica';
  });
  if (jaExiste) return;
  ScriptApp.newTrigger('executarExportacaoAutomatica')
    .timeBased()
    .everyDays(1)
    .atHour(4)
    .create();
  Logger.log("Gatilho diário de exportação automática (executarExportacaoAutomatica) criado — roda todo dia por volta das 4h, e decide sozinho (a cada execução) se é dia de exportar de acordo com a frequência configurada.");
}
// Roda todo dia (via gatilho acima) mas só realmente exporta quando a frequência configurada bate com
// o dia de hoje: 'diaria' sempre exporta; 'semanal' só às segundas-feiras; 'mensal' só todo dia 1º.
// Se "Seção" estiver vazia (Nenhuma/desativada), não faz nada.
function executarExportacaoAutomatica() {
  try {
    var secao = obterConfigValor_('exportAutoSecao', '');
    if (!secao || !SECAO_SHEETS_EXPORT[secao]) return;
    var frequencia = obterConfigValor_('exportAutoFrequencia', 'diaria');
    var hoje = new Date();
    var diaSemana = hoje.getDay(); // 0=domingo ... 1=segunda
    var diaMes = hoje.getDate();
    if (frequencia === 'semanal' && diaSemana !== 1) return;
    if (frequencia === 'mensal' && diaMes !== 1) return;

    var pasta = obterOuCriarPastaExportacoes_();
    var dataStr = Utilities.formatDate(hoje, Session.getScriptTimeZone(), "dd-MM-yyyy");
    var nomeArquivo = "Exportacao-Automatica_" + secao + "_" + dataStr;
    var origem = SpreadsheetApp.getActiveSpreadsheet();
    var novaPlanilha = SpreadsheetApp.create(nomeArquivo);

    (SECAO_SHEETS_EXPORT[secao] || []).forEach(function(nomeAba) {
      var abaOrig = origem.getSheetByName(nomeAba);
      if (!abaOrig) return;
      var copia = abaOrig.copyTo(novaPlanilha);
      copia.setName(nomeAba);
    });
    // A planilha nova nasce com uma aba padrão em branco ("Sheet1"/"Página1") — remove, já que as
    // abas de verdade (cópias acima) já cobrem os dados; só não remove se por algum motivo nenhuma
    // aba tiver sido copiada (evita ficar com uma planilha sem nenhuma aba, o que dá erro).
    var abaPadrao = novaPlanilha.getSheetByName('Sheet1') || novaPlanilha.getSheetByName('Página1');
    if (abaPadrao && novaPlanilha.getSheets().length > 1) novaPlanilha.deleteSheet(abaPadrao);

    var arquivoNovo = DriveApp.getFileById(novaPlanilha.getId());
    pasta.addFile(arquivoNovo);
    DriveApp.getRootFolder().removeFile(arquivoNovo); // sai da raiz do Drive, fica só na pasta de exportações
    Logger.log("Exportação automática (" + secao + ", " + frequencia + ") gerada: " + nomeArquivo);
  } catch (e) { logErro('executarExportacaoAutomatica', e); }
}

// V148: fazerBackupDiario() já existia (copia o arquivo inteiro da planilha pro Drive), mas nunca
// tinha um gatilho (trigger) instalado — ou seja, nunca rodava sozinha. Esta função cria o gatilho
// diário automaticamente (idempotente: só cria se ainda não existir), então basta rodar
// prepararPlanilhas() uma vez (mesmo passo que já é pedido no Manual de Uso) para o backup diário
// completo passar a acontecer sozinho, além do snapshot que já roda a cada salvamento (fazerBackup()).
// V180: agora respeita "backupAutoHabilitado" (sim/nao, padrão sim) e "backupAutoHora" (0-23, padrão
// 3) — configuráveis em Configurações Avançadas. Sempre remove e recria o gatilho existente pra
// garantir que a hora configurada mais recente é respeitada (roda só quando chamada explicitamente
// por configurarBackupAutomatico() ou prepararPlanilhas(), nunca a cada requisição — sem custo extra).
function garantirTriggerBackupDiario() {
  const habilitado = obterConfigValor_('backupAutoHabilitado', 'sim') !== 'nao';
  const horaConfigurada = parseInt(obterConfigValor_('backupAutoHora', '3'), 10);
  const hora = (isNaN(horaConfigurada) || horaConfigurada < 0 || horaConfigurada > 23) ? 3 : horaConfigurada;
  const triggersExistentes = ScriptApp.getProjectTriggers().filter(function(t) {
    return t.getHandlerFunction() === 'fazerBackupDiario';
  });
  if (!habilitado) {
    triggersExistentes.forEach(function(t) { ScriptApp.deleteTrigger(t); });
    if (triggersExistentes.length) Logger.log("Backup diário automático desativado — gatilho removido.");
    return;
  }
  triggersExistentes.forEach(function(t) { ScriptApp.deleteTrigger(t); });
  ScriptApp.newTrigger('fazerBackupDiario')
    .timeBased()
    .everyDays(1)
    .atHour(hora)
    .create();
  Logger.log("Gatilho diário de backup completo (fazerBackupDiario) criado/atualizado — roda todo dia por volta das " + hora + "h.");
}
