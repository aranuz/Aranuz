/* ====== GENÉRICO ====== */
// V78: se uma linha for importada manualmente direto na planilha sem preencher a coluna "id", ela ganha
// um ID novo automaticamente — e esse ID é GRAVADO de volta na própria célula da planilha (não é só
// gerado na memória a cada leitura, o que geraria um ID diferente toda vez e quebraria vínculos).
// V2.99 — 13/07/2026: garantirIdsGravados_() e lerGenerico() passaram a ler cada coluna pelo NOME do
// cabeçalho (colMap, igual ao que lerFornecedores()/lerProjetos()/lerFinanceiro()/lerOrcamentos()/
// lerFuncionarios()/lerEquipamentos() já faziam) em vez de assumir que a posição (índice) de cada coluna
// no array *_COLS bate com a posição real na planilha. Antes, se a ordem das colunas na aba não fosse
// EXATAMENTE igual à ordem declarada no código (por exemplo, após uma cópia de uma planilha antiga,
// gerada por uma versão anterior deste arquivo, ou qualquer edição manual que reordenasse colunas), a
// leitura podia silenciosamente pegar o valor da coluna errada — sem erro nenhum, só dado errado. Como
// gravarGenerico() sempre reescreve a aba inteira na ordem canônica a cada gravação, esse desalinhamento
// só existia até a primeira gravação — mas a leitura ANTES disso (ex.: a primeira sincronização depois de
// uma migração de dados) podia ler errado. Afeta ~24 abas que passam por lerGenerico() (Clientes,
// Histórico, Locações, Itens de Locação/Orçamento/Proposta, Catálogos, NPS, Contratos e outras).
function garantirIdsGravados_(aba, colunas, valores, colMap) {
  var idColIdx = colMap ? colMap["id"] : colunas.indexOf("id");
  if (idColIdx === undefined || idColIdx === -1) return valores;
  var precisaGravar = false;
  for (var i = 0; i < valores.length; i++) {
    var linha = valores[i];
    if (linha.join("").trim() === "") continue;
    var idAtual = linha[idColIdx];
    if (idAtual === "" || idAtual === null || idAtual === undefined || idAtual === 0) {
      var novoId = Date.now() + i;
      linha[idColIdx] = novoId;
      aba.getRange(i + 2, idColIdx + 1).setValue(novoId); // +2: pula o cabeçalho (linha 1) e é 1-indexado
      precisaGravar = true;
    }
  }
  return valores;
}
function lerGenerico(sheetName, colunas, dateFields, jsonFields) {
  var aba = obterAba(sheetName, colunas);
  var valores = aba.getDataRange().getValues();
  if (valores.length < 2) return [];
  var hdr = valores.shift();
  var colMap = {};
  hdr.forEach(function(h, i) { colMap[String(h).trim()] = i; });
  valores = garantirIdsGravados_(aba, colunas, valores, colMap);
  return valores.filter(function(l) { return l.join("").trim() !== ""; }).map(function(linha) {
    var obj = {};
    colunas.forEach(function(col) {
      var idx = colMap[col];
      var val = (idx !== undefined && linha[idx] !== undefined) ? linha[idx] : "";
      if (dateFields && dateFields.indexOf(col) !== -1) val = ymd(val);
      if (col === "updatedAt") val = Number(val) || 0;
      // V2.50: colunas declaradas em jsonFields guardam um array/objeto serializado em JSON (ver
      // gravarGenerico logo abaixo) — desserializa de volta; célula vazia ou JSON inválido vira [].
      if (jsonFields && jsonFields.indexOf(col) !== -1) { try { val = val ? JSON.parse(val) : []; } catch (e) { val = []; } }
      obj[col] = val;
    });
    return obj;
  });
}

function gravarGenerico(sheetName, colunas, dados) {
  var aba = obterAba(sheetName, colunas);
  aba.clearContents();
  aba.getRange(1,1,1,colunas.length).setValues([colunas]);
  if (dados && dados.length > 0) {
    // V2.50: qualquer valor que não seja primitivo (array/objeto — ex: "tags", "gruposDespesa") vira uma
    // string JSON na célula, em vez de quebrar o setValues (que só aceita primitivos). Ver o par
    // jsonFields em lerGenerico(), acima, pra desserializar de volta na leitura.
    var rows = dados.map(function(obj) { return colunas.map(function(col) {
      var v = obj[col];
      if (v === undefined || v === null) return "";
      if (typeof v === "object") return JSON.stringify(v);
      return v;
    }); });
    aba.getRange(2,1,rows.length,colunas.length).setValues(rows);
  }
}

// V139 — sistema de arquivamento automático do Histórico. O app já manda no máximo HISTORY_MAX_LINHAS
// (3000, ver addHistory no HTML) por sincronização, mas esta é a rede de segurança do lado da planilha:
// se por qualquer motivo (dispositivo com versão antiga, edição manual etc.) chegar mais linha que
// HIST_LIMITE_LINHAS, o excedente mais antigo é movido pra uma aba nova "Histórico - Arquivo N" em vez
// de simplesmente descartado — os dados continuam acessíveis direto na planilha, só saem da leitura
// ativa do app (que só precisa do histórico recente no dia a dia).
var HIST_LIMITE_LINHAS = 4000;
var HIST_LINHAS_POR_ARQUIVO = 20000; // Sheets aguenta bem mais, mas isso já é mais que suficiente por aba

function gravarHistoricoComArquivamento(dados) {
  dados = dados || [];
  if (dados.length > HIST_LIMITE_LINHAS) {
    // db.history vem do app mais-recente-primeiro (unshift) — o excedente (mais antigo) fica no final.
    var excedente = dados.slice(HIST_LIMITE_LINHAS);
    dados = dados.slice(0, HIST_LIMITE_LINHAS);
    arquivarHistoricoExcedente_(excedente);
  }
  gravarGenerico(SHEET_HIS, HIS_COLS, dados);
}

function arquivarHistoricoExcedente_(linhasAntigas) {
  if (!linhasAntigas || !linhasAntigas.length) return;
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var n = 1, aba, nomeAba;
  // Acha a primeira aba de arquivo com espaço livre, criando uma nova numerada quando a atual encher.
  while (true) {
    nomeAba = SHEET_HIS + " - Arquivo " + n;
    aba = ss.getSheetByName(nomeAba);
    if (!aba) { aba = ss.insertSheet(nomeAba); aba.getRange(1,1,1,HIS_COLS.length).setValues([HIS_COLS]); break; }
    if (aba.getLastRow() < HIST_LINHAS_POR_ARQUIVO) break;
    n++;
  }
  var proximaLinha = aba.getLastRow() + 1;
  var rows = linhasAntigas.map(function(obj) { return HIS_COLS.map(function(col) { return obj[col] !== undefined ? obj[col] : ""; }); });
  aba.getRange(proximaLinha, 1, rows.length, HIS_COLS.length).setValues(rows);
}

