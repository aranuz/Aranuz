// Relatório Financeiro Agendado: entradas, saídas e saldo do período (semana ou mês anterior, conforme
// frequência configurada), mais o total ainda pendente de pagamento/recebimento.
function enviarRelatorioFinanceiroPorEmail_() {
  try {
    if (obterConfigValor_('relatorioFinanceiroEmailAtivo', 'nao') !== 'sim') return;
    var frequencia = obterConfigValor_('relatorioFinanceiroFrequencia', 'mensal');
    var hoje = new Date();
    // O gatilho de frequência 'mensal' roda todo dia (ver garantirTriggerRelatorioFinanceiroEmail_) —
    // só segue em frente de verdade no dia 1 do mês, senão sai sem fazer nada nem gastar cota de e-mail.
    if (frequencia === 'mensal' && hoje.getDate() !== 1) return;

    var inicioPeriodo, fimPeriodo, labelPeriodo;
    if (frequencia === 'semanal') {
      fimPeriodo = hoje;
      inicioPeriodo = new Date(hoje.getTime() - 7 * 24 * 60 * 60 * 1000);
      labelPeriodo = 'semana de ' + Utilities.formatDate(inicioPeriodo, Session.getScriptTimeZone(), 'dd/MM') + ' a ' + Utilities.formatDate(fimPeriodo, Session.getScriptTimeZone(), 'dd/MM/yyyy');
    } else {
      // mês anterior completo (relatório do dia 1 sempre olha pro mês que acabou de fechar).
      var mesAnterior = new Date(hoje.getFullYear(), hoje.getMonth() - 1, 1);
      inicioPeriodo = mesAnterior;
      fimPeriodo = new Date(hoje.getFullYear(), hoje.getMonth(), 0); // último dia do mês anterior
      labelPeriodo = Utilities.formatDate(mesAnterior, Session.getScriptTimeZone(), 'MMMM/yyyy');
    }

    var destinatarios = obterConfigValor_('emailDestinatariosAlertas', '') || obterConfigValor_('emailEmpresa', '');
    if (!destinatarios) { logErro('enviarRelatorioFinanceiroPorEmail_', new Error('Sem destinatários configurados.')); return; }
    var remetenteNome = obterConfigValor_('emailRemetenteNome', '') || obterConfigValor_('nomeFantasia', '') || 'Aranuz';

    var financeiro = lerFinanceiro();
    var doPeriodo = financeiro.filter(function(f){
      if (!f.data) return false;
      var d = new Date(f.data);
      return d >= inicioPeriodo && d <= fimPeriodo;
    });
    var entradas = 0, saidas = 0, pendentes = 0;
    doPeriodo.forEach(function(f){
      if (f.tipoMovimento === 'entrada') entradas += (f.valor||0); else if (f.tipoMovimento === 'saida') saidas += (f.valor||0);
      if (String(f.status).toLowerCase() !== 'pago') pendentes += (f.valor||0);
    });
    var saldo = entradas - saidas;

    var corpo = '<h2 style="margin:0 0 12px;">💰 Relatório Financeiro — ' + labelPeriodo + '</h2>'
      + '<table style="font-size:13px; border-collapse:collapse; width:100%; max-width:420px;">'
      + '<tr><td style="padding:6px 0;">Entradas</td><td style="text-align:right; font-weight:700; color:#059669;">R$ ' + entradas.toFixed(2) + '</td></tr>'
      + '<tr><td style="padding:6px 0;">Saídas</td><td style="text-align:right; font-weight:700; color:#dc2626;">R$ ' + saidas.toFixed(2) + '</td></tr>'
      + '<tr><td style="padding:6px 0; border-top:1px solid #ddd;">Saldo do período</td><td style="text-align:right; font-weight:700; border-top:1px solid #ddd;">R$ ' + saldo.toFixed(2) + '</td></tr>'
      + '<tr><td style="padding:6px 0;">Ainda pendente (não pago/recebido, no período)</td><td style="text-align:right;">R$ ' + pendentes.toFixed(2) + '</td></tr>'
      + '</table>';

    if (obterConfigValor_('relatorioIncluirLeads', 'sim') === 'sim') {
      var leads = lerOportunidades().filter(function(l){ if(!l.dateIn) return false; var d = new Date(l.dateIn); return d >= inicioPeriodo && d <= fimPeriodo; });
      corpo += '<h3 style="margin:20px 0 8px;">📈 Leads e Oportunidades</h3>'
        + '<p style="font-size:13px; margin:0;">' + leads.length + ' novo(s) lead(s) entraram no funil no período.</p>';
    }
    if (obterConfigValor_('relatorioIncluirProjetos', 'sim') === 'sim') {
      var projetos = lerProjetos().filter(function(p){ if(!p.deadline) return false; var d = new Date(p.deadline); return d >= inicioPeriodo && d <= fimPeriodo && (p.stage === 'Finalizado' || p.stage === 'Entregue'); });
      corpo += '<h3 style="margin:20px 0 8px;">📁 Projetos</h3>'
        + '<p style="font-size:13px; margin:0;">' + projetos.length + ' projeto(s) concluído(s)/entregue(s) no período.</p>';
    }
    if (obterConfigValor_('relatorioIncluirNps', 'sim') === 'sim') {
      var npsPeriodo = lerNps().filter(function(n){ if(!n.data) return false; var d = new Date(n.data); return d >= inicioPeriodo && d <= fimPeriodo; });
      var mediaNps = npsPeriodo.length ? (npsPeriodo.reduce(function(s,n){ return s + (parseFloat(n.nota)||0); }, 0) / npsPeriodo.length) : null;
      corpo += '<h3 style="margin:20px 0 8px;">⭐ NPS</h3>'
        + '<p style="font-size:13px; margin:0;">' + (mediaNps != null ? ('Nota média: ' + mediaNps.toFixed(1) + ' (' + npsPeriodo.length + ' resposta(s))') : 'Sem respostas de NPS no período.') + '</p>';
    }
    corpo += '<p style="font-size:11px; color:#999; margin-top:16px;">Relatório automático (' + (frequencia === 'semanal' ? 'semanal' : 'mensal') + ') do Aranuz — pode ser desativado, e as seções ajustadas, em Configurações Avançadas &gt; E-mails e Alertas.</p>';

    var anexos = [];
    try {
      var pdfBlob = Utilities.newBlob(corpo, 'text/html', 'Relatorio-Aranuz-' + labelPeriodo.replace(/\//g,'-') + '.html').getAs('application/pdf');
      pdfBlob.setName('Relatorio-Aranuz-' + labelPeriodo.replace(/\//g,'-') + '.pdf');
      anexos.push(pdfBlob);
    } catch (ePdf) { logErro('enviarRelatorioFinanceiroPorEmail_[pdf]', ePdf); }

    _enviarEmailApp_(destinatarios, remetenteNome, '💰 Relatório Financeiro — ' + labelPeriodo, corpo, anexos);
  } catch (e) { logErro('enviarRelatorioFinanceiroPorEmail_', e); }
}

