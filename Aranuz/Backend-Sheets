// usado por rotinas do próprio backend (triggers) que não recebem o db.configuracoes do front-end.
function obterConfigValor_(chave, padrao) {
  try {
    var linhas = lerConfiguracoes();
    for (var i = 0; i < linhas.length; i++) {
      if (linhas[i].chave === chave) {
        var v = linhas[i].valor;
        if (v === '' || v === null || typeof v === 'undefined') return padrao;
        return v;
      }
    }
    return padrao;
  } catch (e) { logErro('obterConfigValor_', e); return padrao; }
}
// V160: grava (ou atualiza) uma única chave de configuração direto na planilha — usado pelas ações
// pontuais 'configurarExportacaoAutomatica' etc., que não mandam o db.configuracoes inteiro.
function definirConfigValor_(chave, valor) {
  try {
    var linhas = lerConfiguracoes();
    var achou = false;
    for (var i = 0; i < linhas.length; i++) {
      if (linhas[i].chave === chave) { linhas[i].valor = valor; linhas[i].updatedAt = Date.now(); achou = true; break; }
    }
    if (!achou) linhas.push({ chave: chave, valor: valor, updatedAt: Date.now() });
    gravarConfiguracoes(linhas);
  } catch (e) { logErro('definirConfigValor_', e); }
}
