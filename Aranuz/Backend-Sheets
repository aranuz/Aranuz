// só sem esse preenchimento automático. IMPORTANTE: isso é uma correspondência por nome, não uma
// confirmação de que o link é realmente da empresa certa (nomes comuns podem trazer o LinkedIn errado)
// — o campo continua editável no Perfil do Lead pra corrigir/confirmar manualmente. Prioriza
// linkedin.com/company (perfil de empresa) sobre linkedin.com/in (perfil pessoal), que não interessa
// aqui. Nível gratuito da API: 100 buscas/dia — acima disso passa a ser cobrado por uso (ver Google
// Cloud Console), por isso não faz sentido chamar isso em loop sem limite nenhum.
function _buscarLinkedinDaEmpresa_(nome, cidade) {
  var cseKey = obterGoogleCseKey_(), cseCx = obterGoogleCseCx_();
  if (!cseKey || !cseCx || !nome) return "";
  try {
    var query = '"' + nome + '" ' + (cidade || '') + ' linkedin';
    var url = "https://www.googleapis.com/customsearch/v1?key=" + encodeURIComponent(cseKey) +
      "&cx=" + encodeURIComponent(cseCx) + "&num=5&q=" + encodeURIComponent(query);
    var res = UrlFetchApp.fetch(url, { muteHttpExceptions: true });
    if (res.getResponseCode() !== 200) return "";
    var items = (JSON.parse(res.getContentText()).items) || [];
    var candidatoEmpresa = null, candidatoPessoal = null;
    for (var i = 0; i < items.length; i++) {
      var link = items[i].link || "";
      if (!/linkedin\.com/i.test(link)) continue;
      if (/linkedin\.com\/company\//i.test(link) && !candidatoEmpresa) candidatoEmpresa = link;
      else if (/linkedin\.com\/in\//i.test(link) && !candidatoPessoal) candidatoPessoal = link;
    }
    // Só devolve perfil de empresa — perfil pessoal (candidatoPessoal) fica de fora de propósito, porque
    // não é o que o campo "LinkedIn (Empresa)" do lead espera.
    return candidatoEmpresa || "";
  } catch (err) { logErro('_buscarLinkedinDaEmpresa_', err); return ""; }
}

/* ====== RADAR (Google Places) ====== */
// V221: correção do bug relatado pelo cliente — buscar leads pelo Radar deixava o app "bugado" e o
// sync quebrado depois. Causa raiz encontrada: (1) esta função lia E reescrevia a aba de Oportunidades
// INTEIRA a cada busca (lerOportunidades() parseando anos de leads acumulados, um por um, incluindo o
// JSON de histórico de cada um, só pra descobrir quais nomes já existiam — depois clearContents() +
// reescrita de tudo de novo), ficando mais lento e mais pesado a cada empresa nova que entrava; (2) essa
// escrita não tinha NENHUM lock (diferente de doPost(), que já usa LockService desde a V170 exatamente
// pra evitar isso) — uma sincronização normal rodando ao mesmo tempo (POST) podia se intercalar com essa
// escrita do Radar e uma sobrescrever a outra, corrompendo os dados e deixando sincronizações seguintes
// "perdidas". Agora: os nomes já existentes vêm de uma leitura enxuta (só a coluna "empresa", ver
// _nomesOportunidadesExistentes_()), e as empresas novas são só ADICIONADAS ao final da aba (ver
// _appendOportunidades_()) — sem tocar nas linhas já existentes — dentro do mesmo LockService usado em
// doPost(), serializando com qualquer sincronização normal em andamento.
// V238 — BUGFIX: buscarRadar() grava os leads novos direto na planilha (_appendOportunidades_(), only
// server-side) mas isso nunca passava pelo espelhamento incremental pro Firestore (que só é disparado
// pelo _flushDb() do navegador). Resultado relatado: lead aparecia na planilha mas sumia no app, porque
// a leitura de "leads" hoje tenta o Firestore primeiro e ele respondia normalmente (só que sem os leads
// novíssimos) — nunca caindo pro fallback da planilha. Correção: a resposta agora inclui o array "novos"
// inteiro (não só a contagem) — o navegador (triggerRadarSearch(), no .html) funde esses leads no db.leads
// local e chama saveDb(), que já aciona o espelhamento incremental pro Firestore normalmente.
function buscarRadar(cidade, segmento) {
  var googleKey = obterGooglePlacesKey_();
  if (!googleKey) return json({ erro: "Configure a Chave da API do Google Places em Configurações do App > Radar de Leads." });
  var termos = SEGMENT_TERMS[segmento] || SEGMENT_TERMS.todos;
  var termoSorteado = termos[Math.floor(Math.random()*termos.length)];
  var res = UrlFetchApp.fetch("https://places.googleapis.com/v1/places:searchText", {
    method:"post", contentType:"application/json",
    headers:{ "X-Goog-Api-Key":googleKey, "X-Goog-FieldMask":"places.displayName,places.primaryTypeDisplayName,places.websiteUri,places.nationalPhoneNumber,places.formattedAddress" },
    payload: JSON.stringify({ textQuery: termoSorteado+" em "+cidade, languageCode:"pt-BR", maxResultCount:20 }), muteHttpExceptions:true });
  if (res.getResponseCode() !== 200) return json({ erro:"Google Places retornou erro." });
  var places = (JSON.parse(res.getContentText()).places) || [];
  var nomes = _nomesOportunidadesExistentes_();
  var proib = ["igreja","paróquia","paroquia","templo","santuário","santuario","capela","mesquita","sinagoga","terreiro","centro espírita","centro espirita","congregação","arquidiocese","deus","cristã","cristão","evangélica","evangelica","batista","presbiteriana"];
  var novos = []; var rejeitadas = 0;
  places.forEach(function(pl) {
    var nome = pl.displayName ? pl.displayName.text : ""; var tipoLugar = pl.primaryTypeDisplayName ? pl.primaryTypeDisplayName.text : "";
    if (!nome || nomes[nome.toLowerCase().trim()]) return;
    if (!pl.websiteUri) { rejeitadas++; return; }
    var nl = nome.toLowerCase(), tl = tipoLugar.toLowerCase();
    if (proib.some(function(t) { return nl.includes(t) || tl.includes(t); })) { rejeitadas++; return; }
    var mocoes=0, resumo="Nenhuma menção recente.";
    try { 
      var rn = UrlFetchApp.fetch("https://news.google.com/rss/search?q="+encodeURIComponent(nome)+"&hl=pt-BR&gl=BR&ceid=BR:pt-419",{muteHttpExceptions:true});
      if (rn.getResponseCode()===200){ var c=(rn.getContentText().match(/<item>/g)||[]).length; if(c>0){ mocoes=c; resumo="Ativa na mídia. "+c+" menções."; } } 
    } catch(err){}
    var align = Math.min(mocoes*6,35);
    // V2.45 — busca best-effort do LinkedIn da empresa (ver _buscarLinkedinDaEmpresa_ acima); fica "" em
    // silêncio se a Busca Personalizada do Google não estiver configurada ou não achar nada com confiança.
    var linkedinAchado = _buscarLinkedinDaEmpresa_(nome, cidade);
    // V219: lead capturado no segmento "Agências de Publicidade e Marketing" (chave "agencias" em
    // SEGMENTOS_ICP, no HTML) entra com Tipo de Cliente "Agência" em vez de "Cliente Final" — os demais
    // segmentos continuam como "Cliente Final", igual antes.
    // V2.45 — pedido do cliente: todo lead que entra pela busca automática do Radar já nasce com a
    // "Origem do Lead" (origemCanal, campo visível no Perfil do Lead) preenchida como "Sistema de Busca" —
    // antes só existia o campo interno "origem" ("radar"), que não é o mesmo campo mostrado na tela.
    novos.push({ id:Date.now()+Math.floor(Math.random()*1000000), dateIn:dataHojeBR(), company:nome, segment:tipoLugar||termoSorteado, city:cidade, state:"ES",
      clientType:(segmento === "agencias" ? "Agência" : "Cliente Final"), stage:0, nextAction:"", companyPhone:pl.nationalPhoneNumber||"", site:pl.websiteUri||"", instagram:"", linkedin:linkedinAchado,
      score:{mkt:35,fin:30,align:align}, decisor:{nome:"",cargo:"",tel:"",email:"",linkedin:""}, influenciador:{nome:"",cargo:"",tel:"",email:"",linkedin:""},
      dores:resumo, gatilho:mocoes>0?"Presença na Mídia":"", maturidade:mocoes>5?"Alta (Foco em PR)":"Média",
      pitch:mocoes>0?"Parabenizar pelas aparições na mídia.":"Mapear posicionamento.",
      history:[{date:new Date().toLocaleString('pt-BR'),text:"Adicionado via Radar IA ("+segmento+")."}], origem:"radar", origemCanal:"Sistema de Busca",
      qualification:"pendente", updatedAt:Date.now() });
    nomes[nome.toLowerCase().trim()]=1;
  });
  if (novos.length) {
    // V221: lock só em volta da escrita (rápida — é só um "append"), não das chamadas ao Google Places/
    // Google News acima (que podem demorar) — mesma lógica de doPost(), pra não segurar outras
    // sincronizações esperando por mais tempo do que o necessário.
    var lock = LockService.getScriptLock();
    var lockOk = true;
    try { lock.waitLock(25000); } catch (lockErr) { lockOk = false; logErro('buscarRadar_lock', lockErr); }
    try { _appendOportunidades_(novos); } finally { if (lockOk) { try { lock.releaseLock(); } catch (releaseErr) {} } }
  }
  return json({ ok:true, adicionadas:novos.length, rejeitadas:rejeitadas, novos:novos });
}

/* ====== UTILITÁRIOS ====== */
// V184: registra sucesso/falha de cada execução na tabela de Configurações ("backupAutoUltimoOk"/
// "backupAutoUltimoErro"), pra o front-end poder avisar (alerta desligável) se o backup diário parar
// de funcionar silenciosamente — antes, uma falha aqui (permissão revogada, Drive cheio etc.) só
// aparecia no Log de execução do Apps Script, que ninguém olha no dia a dia.
// V222: parâmetro "manual" novo (opcional, default false) — quando true, o nome do arquivo ganha um
// sufixo "_Manual_HHmm" pra não ficar indistinguível do backup automático do mesmo dia no Drive. O
// gatilho diário (ScriptApp) sempre chama esta função SEM argumento, então o comportamento de sempre
// (nome "Backup_MHub_dd-MM-yyyy", sem sufixo) continua idêntico pro backup automático. Ver
// fazerBackupAgoraEndpoint_(), chamada pelo botão "Fazer Backup Agora" em Configurações Avançadas.
function fazerBackupDiario(manual) {
  try {
    var planilha = SpreadsheetApp.getActiveSpreadsheet();
    var arquivo = DriveApp.getFileById(planilha.getId());
    var dataHoje = Utilities.formatDate(new Date(), Session.getScriptTimeZone(), "dd-MM-yyyy");
    var pasta = arquivo.getParents().hasNext() ? arquivo.getParents().next() : DriveApp.getRootFolder();
    // V183: prefixo do arquivo trocado de "Backup_MangFilm_" pra "Backup_MHub_" (limpeza de nome
    // próprio fixo no código). A rotina de retenção abaixo reconhece os dois prefixos, pra continuar
    // contando/limpando corretamente os backups antigos já criados com o nome anterior.
    // V2.93 — 11/07/2026: troca de marca (M-Hub -> Maram Workspace) — prefixo novo passou a ser
    // "Backup_Maram_". A rotina de retenção abaixo passou a reconhecer os TRÊS prefixos (Maram, MHub,
    // MangFilm), pra continuar contando/limpando certo os backups de qualquer época, sem perder histórico.
    // V2.94 — 12/07/2026: segunda troca de marca (Maram Workspace -> Aranuz) — prefixo novo é
    // "Backup_Aranuz_". A rotina de retenção abaixo agora reconhece os QUATRO prefixos (Aranuz, Maram,
    // MHub, MangFilm), pra continuar contando/limpando certo os backups de qualquer época, sem perder
    // histórico nenhum.
    var nomeArquivo = "Backup_Aranuz_" + dataHoje;
    if (manual) nomeArquivo += "_Manual_" + Utilities.formatDate(new Date(), Session.getScriptTimeZone(), "HHmm");
    arquivo.makeCopy(nomeArquivo, pasta);
    // Mantém só os últimos N backups diários — sem isso, a pasta do Drive cresceria pra sempre.
    // V158: N era fixo em 30; agora é configurável (Configurações do App > Retenção de Backups),
    // guardado na chave "retencaoBackups". 30 continua sendo o padrão se nada for configurado.
    try {
      var prefixos = ["Backup_Aranuz_", "Backup_Maram_", "Backup_MHub_", "Backup_MangFilm_"];
      var arquivos = [];
      var it = pasta.getFilesByName ? null : null; // no-op, mantém compat
      var lista = pasta.getFiles();
      while (lista.hasNext()) {
        var f = lista.next();
        var nomeArq = String(f.getName());
        if (prefixos.some(function(p) { return nomeArq.indexOf(p) === 0; })) arquivos.push(f);
      }
      arquivos.sort(function(a, b) { return b.getDateCreated() - a.getDateCreated(); });
      var limiteRetencao = parseInt(obterConfigValor_('retencaoBackups', 30), 10);
      if (!limiteRetencao || limiteRetencao < 1) limiteRetencao = 30;
      for (var i = limiteRetencao; i < arquivos.length; i++) { arquivos[i].setTrashed(true); }
    } catch (e) { logErro('fazerBackupDiario_limpeza', e); }
    definirConfigValor_('backupAutoUltimoOk', Date.now());
    definirConfigValor_('backupAutoUltimoErro', '');
  } catch (e) {
    logErro('fazerBackupDiario', e);
    definirConfigValor_('backupAutoUltimoErro', String(e && e.message || e));
  }
}
// V222: endpoint chamado via doGet (?fazerBackupAgora=1) pelo botão "Fazer Backup Agora" em
// Configurações Avançadas — dispara o mesmo backup completo pro Drive que já roda sozinho todo dia
// (fazerBackupDiario), mas na hora, e devolve o resultado direto na resposta (sucesso/erro), sem
// depender de um POST "no-cors" (que não permite ler a resposta) nem esperar o próximo sync pra saber
// se deu certo.
function fazerBackupAgoraEndpoint_() {
  try {
    fazerBackupDiario(true);
    var erro = obterConfigValor_('backupAutoUltimoErro', '');
    if (erro) return json({ ok: false, erro: erro });
    return json({ ok: true, quando: Number(obterConfigValor_('backupAutoUltimoOk', 0)) || Date.now() });
  } catch (e) {
    logErro('fazerBackupAgoraEndpoint_', e);
    return json({ ok: false, erro: String(e && e.message || e) });
  }
}