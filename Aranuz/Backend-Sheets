// V2.73 — 10/07/2026 21:00: o backend passa a espelhar, também, os 3 cadastros vindos dos formulários
// públicos (Clientes, Fornecedores, NPS) direto no Firestore — hoje eles só caíam na planilha Sheets, e
// só chegavam ao Firestore quando alguém abria o app (que puxa a planilha e re-espelha). Agora o
// cadastro aparece no app quase na hora, sem precisar dessa volta.
//
// Decisão de arquitetura (perguntada e confirmada com o cliente): a GRAVAÇÃO é feita por ESTE backend
// (.gs), usando a identidade da própria conta Google que roda o Apps Script (OAuth2, via
// ScriptApp.getOAuthToken()) — nenhuma escrita pública fica exposta no Firestore, diferente da
// alternativa (os HTMLs públicos gravando direto do navegador de quem preenche, que exigiria Regras de
// Segurança abertas pra escrita anônima).
//
// CONFIGURAÇÃO NECESSÁRIA (uma vez só, ver manual do app — tópico "Integração com Firestore"):
//   1) No editor do Apps Script: ⚙️ Configurações do Projeto > marque "Mostrar arquivo de manifesto
//      appsscript.json na Editor". Abra o appsscript.json e garanta que "oauthScopes" inclui
//      "https://www.googleapis.com/auth/datastore" (além dos escopos que já existirem — não remova
//      nenhum). Salve e reautorize o projeto (rode qualquer função uma vez, aceite as novas permissões).
//   2) A conta Google dona deste Apps Script precisa ter acesso (Editor, ou o papel "Cloud Datastore
//      User") ao projeto do Google Cloud identificado por FIRESTORE_PROJECT_ID (mais abaixo neste
//      arquivo, mesmo Project ID do Firebase) — normalmente já tem, se foi quem criou o projeto Firebase.
//   3) Dentro do app: Configurações Avançadas > Integração com Firestore > cole o "ID da Empresa
//      (Firebase)" (copie do Painel de Diagnóstico, no menu do app) no campo correspondente e salve.
//      Enquanto esse campo estiver vazio, a gravação no Firestore fica DESLIGADA — é o fail-safe: nunca
//      tenta gravar em um lugar adivinhado. A planilha Sheets continua funcionando normalmente, como
//      sempre, independentemente disso.
var FIRESTORE_PROJECT_ID = 'aranuz-6c80c'; // V3.06 — preenchido com o Project ID do Firebase novo/definitivo (era placeholder desde a V2.95)
function _firestoreEmpresaId_() { return obterConfigValor_('firestoreEmpresaId', ''); }
// Converte um valor JS comum (string, número, boolean, null, array, objeto) pro formato tipado que a
// API REST do Firestore exige — cada campo precisa vir marcado com seu tipo (stringValue, integerValue
// etc.), diferente do SDK do navegador (usado no app), que faz essa conversão sozinho. Mesma ideia do
// sanitizarParaFirestore_() do app (nested arrays viram {mhubArr:[...]}) — aqui já sai pronto no formato
// da API.
function _valorParaFirestoreRest_(v) {
  if (v === undefined || v === null) return { nullValue: null };
  if (typeof v === 'boolean') return { booleanValue: v };
  if (typeof v === 'number') return (isFinite(v) && Math.floor(v) === v) ? { integerValue: String(v) } : { doubleValue: v };
  if (Object.prototype.toString.call(v) === '[object Date]') return { stringValue: !isNaN(v) ? v.toISOString() : '' };
  if (Array.isArray(v)) {
    var valores = v.map(function(it) { return Array.isArray(it) ? _valorParaFirestoreRest_({ mhubArr: it }) : _valorParaFirestoreRest_(it); });
    return { arrayValue: { values: valores } };
  }
  if (typeof v === 'object') {
    var campos = {};
    for (var k in v) { if (v.hasOwnProperty(k)) campos[k] = _valorParaFirestoreRest_(v[k]); }
    return { mapValue: { fields: campos } };
  }
  return { stringValue: String(v) };
}
function _registroParaFirestoreRest_(obj) {
  var campos = {};
  for (var k in obj) { if (obj.hasOwnProperty(k)) campos[k] = _valorParaFirestoreRest_(obj[k]); }
  return { fields: campos };
}
// Grava (cria ou sobrescreve) UM documento em empresas/{empresaId}/{colecao}/{docId}. Nunca lança erro
// pra fora — se o Firestore não responder, ou a Empresa (Firebase) ainda não estiver configurada, a
// função registra em Log de Erros (só quando é erro de verdade — Empresa não configurada não conta como
// erro, é o estado inicial esperado) e retorna quieta, do mesmo jeito que os demais pontos deste app se
// comportam com o Firestore: a planilha nunca deixa de funcionar por causa dele.
function gravarDocumentoFirestore_(colecao, docId, dados) {
  try {
    var empresaId = _firestoreEmpresaId_();
    if (!empresaId || !docId) return;
    var token = ScriptApp.getOAuthToken();
    var url = 'https://firestore.googleapis.com/v1/projects/' + FIRESTORE_PROJECT_ID +
      '/databases/(default)/documents/empresas/' + encodeURIComponent(empresaId) + '/' + encodeURIComponent(colecao) + '/' + encodeURIComponent(String(docId));
    var resp = UrlFetchApp.fetch(url, {
      method: 'patch',
      contentType: 'application/json',
      headers: { Authorization: 'Bearer ' + token },
      payload: JSON.stringify(_registroParaFirestoreRest_(dados)),
      muteHttpExceptions: true
    });
    var codigo = resp.getResponseCode();
    if (codigo < 200 || codigo >= 300) logErro('gravarDocumentoFirestore_[' + colecao + '/' + docId + ']', new Error('HTTP ' + codigo + ': ' + resp.getContentText()));
  } catch (e) {
    logErro('gravarDocumentoFirestore_[' + colecao + '/' + docId + ']', e);
  }
}
// Espelha um cadastro recém-inserido por um dos 3 formulários públicos — recebe o MESMO objeto "data"
// que já foi gravado na planilha por insertRow() (mesmos nomes de campo, já no formato certo: datas em
// "AAAA-MM-DD", texto simples). Só ajusta "updatedAt" pra um timestamp de verdade (o valor que vem do
// formulário é uma data "AAAA-MM-DD", usada só como referência humana na planilha — o Firestore precisa
// de um número de milissegundos pra decidir qual versão é mais recente ao sincronizar, igual ao resto
// do app faz com stampNow()/Date.now()).
function espelharFormularioPublicoNoFirestore_(colecao, dadosForm) {
  if (!dadosForm || !dadosForm.id) return;
  var copia = {};
  for (var k in dadosForm) { if (dadosForm.hasOwnProperty(k)) copia[k] = dadosForm[k]; }
  copia.updatedAt = Date.now();
  gravarDocumentoFirestore_(colecao, dadosForm.id, copia);
}

/* ====== PORTAL DE ORÇAMENTO ONLINE (Bloco 9) — V2.80 ======
   Página pública (MHub_OrcamentoOnline.html, arquivo à parte — vem no próximo bloco) onde um
   Cliente/Agência já cadastrado monta sozinho um orçamento de Locação de Equipamentos, usando um código
   de acesso próprio (gerado no app, em Clientes > aba Locação). Mesma filosofia de segurança do bloco 4
   (Contato do Site): o navegador de quem preenche NUNCA grava direto no Firestore nem manda o preço final
   — só manda "quero X unidades do item Y, de tal data a tal data" pra este backend, que já é quem detém a
   identidade OAuth de gravação. Preço, disponibilidade e o registro final são sempre recalculados/gravados
   aqui, no servidor.

   Reaproveita o MESMO agrupamento usado pelo construtor interno (EQUIP_CATALOG, no HTML: equipamentos com
   disponivelLocacao=true, agrupados por nome + Kits de DB_CatalogoLocacao) — só que montado a partir da
   leitura direta da planilha, já que a página pública não carrega o app inteiro. O id de cada item de
   grupo de equipamento usa a MESMA fórmula do HTML (equipGroupId), pra casar exatamente com o "itemId"
   já gravado em DB_LocacoesItens/DB_OrcamentoItens quando alguém aluga/orça pelo app. */
function equipGroupId_(nome) { return 'equip-' + encodeURIComponent(String(nome || '').trim().toLowerCase()); }
// Monta o catálogo público (array de {cat, items:[{id,nome,preco,disp}]}) — se dataRetirada/dataDevolucao
// vierem preenchidas ("AAAA-MM-DD"), disp já sai líquida das locações que se sobrepõem a esse período
// (mesma lógica de getDisponibilidade()/getQtdReservada() do HTML, só que lida na planilha).
function catalogoPortalPublico_(dataRetirada, dataDevolucao) {
  var equipamentos = lerEquipamentos();
  var catalogoLocacao = lerCatalogoLocacao();
  var grupos = {};
  equipamentos.forEach(function(eq) {
    if (!eq.disponivelLocacao) return;
    var key = String(eq.nome || '').trim().toLowerCase();
    if (!key) return;
    if (!grupos[key]) grupos[key] = { nome: eq.nome, categoria: eq.categoria || 'Outros', ids: [], preco: eq.valorDiaria || 0 };
    grupos[key].ids.push(String(eq.id));
  });
  var itens = [];
  Object.keys(grupos).forEach(function(key) {
    var g = grupos[key];
    itens.push({ id: equipGroupId_(g.nome), nome: g.nome, categoria: g.categoria, preco: g.preco, disp: g.ids.length });
  });
  (catalogoLocacao || []).forEach(function(it) {
    if (!it.isKit) return;
    itens.push({ id: it.id, nome: it.nome, categoria: it.categoria || 'Outros', preco: it.preco || 0, disp: it.disp || 0 });
  });
  if (dataRetirada && dataDevolucao) {
    var locacoes = lerLocacoes();
    var locacoesItens = lerLocacoesItens();
    var reservado = {};
    locacoes.forEach(function(loc) {
      if (loc.status === 'Devolvida' || loc.status === 'Cancelada') return;
      var li = loc.dataRetirada, lf = loc.dataDevolucaoPrevista;
      if (!li || !lf) return;
      var overlap = (li <= dataDevolucao) && (lf >= dataRetirada);
      if (!overlap) return;
      locacoesItens.filter(function(it) { return it.locacaoId === loc.id; })
        .forEach(function(it) { reservado[it.itemId] = (reservado[it.itemId] || 0) + (parseInt(it.quant, 10) || 0); });
    });
    itens.forEach(function(it) { it.disp = Math.max(0, it.disp - (reservado[it.id] || 0)); });
  }
  var porCategoria = {}, ordem = [];
  itens.forEach(function(it) {
    var cat = it.categoria || 'Outros';
    if (!porCategoria[cat]) { porCategoria[cat] = []; ordem.push(cat); }
    porCategoria[cat].push({ id: it.id, nome: it.nome, preco: it.preco, disp: it.disp });
  });
  return ordem.map(function(cat) { return { cat: cat, items: porCategoria[cat] }; });
}
// Confere o código de acesso contra a coluna "codigoAcessoOrcamento" de DB_Clientes — nunca expõe
// nenhum dado do cliente além do nome, e só devolve catálogo se o código bater com um cliente real.
function validarCodigoPortal_(codigo, dataRetirada, dataDevolucao) {
  try {
    var alvo = String(codigo || '').trim().toUpperCase();
    if (!alvo) return json({ valido: false, mensagem: 'Código de acesso não informado.' });
    var clientes = lerGenerico(SHEET_CLI, CLI_COLS, CLI_DATE_FIELDS, CLI_JSON_FIELDS);
    var cliente = clientes.filter(function(c) { return String(c.codigoAcessoOrcamento || '').trim().toUpperCase() === alvo; })[0];
    if (!cliente) return json({ valido: false, mensagem: 'Código inválido. Confira com quem te enviou o link.' });
    return json({
      valido: true,
      clienteId: cliente.id,
      clienteNome: cliente.nomeFantasia || cliente.razaoSocial || '',
      empresaNome: obterConfigValor_('nomeFantasia', '') || obterConfigValor_('razaoSocial', '') || 'Aranuz',
      impostoNfPct: Number(obterConfigValor_('taxRateAluguel', '4')) || 4,
      catalogo: catalogoPortalPublico_(dataRetirada, dataDevolucao)
    });
  } catch (e) {
    logErro('validarCodigoPortal_', e);
    return json({ valido: false, mensagem: 'Erro no servidor. Tente novamente em instantes.' });
  }
}
// Recebe { codigo, itens:[{itemId,quant,diarias}], dataRetirada, dataDevolucao, projNome } do Portal
// público e grava um Orçamento de Locação de verdade — MESMO formato de um criado dentro do app (ver
// salvarLocOrcamento() no HTML), só que com origemPortal:"sim". Preço e disponibilidade são sempre
// recalculados aqui a partir do catálogo/planilha reais, nunca a partir do que o navegador mandou.
function criarOrcamentoPortal_(dados) {
  try {
    dados = dados || {};
    var alvo = String(dados.codigo || '').trim().toUpperCase();
    if (!alvo) return { success: false, message: 'Código de acesso não informado.' };
    var clientes = lerGenerico(SHEET_CLI, CLI_COLS, CLI_DATE_FIELDS, CLI_JSON_FIELDS);
    var cliente = clientes.filter(function(c) { return String(c.codigoAcessoOrcamento || '').trim().toUpperCase() === alvo; })[0];
    if (!cliente) return { success: false, message: 'Código inválido.' };
    var dataRetirada = String(dados.dataRetirada || '').trim();
    var dataDevolucao = String(dados.dataDevolucao || '').trim();
    if (!dataRetirada || !dataDevolucao) return { success: false, message: 'Informe a data de retirada e de devolução.' };
    var itensPedidos = Array.isArray(dados.itens) ? dados.itens : [];
    if (!itensPedidos.length) return { success: false, message: 'Selecione pelo menos um equipamento.' };
    var catalogo = catalogoPortalPublico_(dataRetirada, dataDevolucao);
    var porId = {};
    catalogo.forEach(function(grupo) { grupo.items.forEach(function(it) { porId[it.id] = it; }); });
    var subtotal = 0, itensGravar = [];
    for (var i = 0; i < itensPedidos.length; i++) {
      var pedido = itensPedidos[i];
      var item = porId[String(pedido.itemId)];
      if (!item) return { success: false, message: 'Um dos itens selecionados não existe mais no catálogo.' };
      var quant = Math.max(0, parseInt(pedido.quant, 10) || 0);
      var diarias = Math.max(1, parseInt(pedido.diarias, 10) || 1);
      if (quant <= 0) continue;
      if (quant > item.disp) return { success: false, message: '"' + item.nome + '" não tem mais disponibilidade suficiente pra esse período (restam ' + item.disp + ').' };
      var total = item.preco * quant * diarias;
      subtotal += total;
      itensGravar.push({ itemId: item.id, nome: item.nome, categoria: item.categoria || '', preco: item.preco, quant: quant, diarias: diarias, total: total });
    }
    if (!itensGravar.length) return { success: false, message: 'Selecione pelo menos um equipamento.' };
    var impostoNfPct = Number(obterConfigValor_('taxRateAluguel', '4')) || 4;
    var impostoNfValor = subtotal * impostoNfPct / 100;
    var totalFinal = subtotal + impostoNfValor;
    var agora = Date.now();
    var orc = {
      id: agora, data: dataHojeBR(), projNome: String(dados.projNome || '').trim() || 'Locação de Equipamentos — Portal Online',
      clienteId: cliente.id, clienteNome: cliente.nomeFantasia || cliente.razaoSocial || '', leadId: '',
      tipo: 'Locação de Equipamentos', valor: Math.round(totalFinal), retorno: '', approved: false, status: 'sem_resposta',
      contatoNome: String(dados.contatoNome || '').trim(), projVinculado: '', dataRetirada: dataRetirada, dataDevolucaoPrevista: dataDevolucao,
      subtotal: subtotal, desconto: 0, pagamento: '', cnpj: '', razaoSocial: '',
      criadoEm: agora, atualizadoEm: agora, propostaLink: '', agenciaNome: '', tipoContrato: 'Pontual',
      categoriaProjeto: 'Aluguel de Equipamentos', origemProposta: '', statusProposta: '',
      grupoPropostaId: 'grp_' + agora, versao: 1, orcamentoLocacaoVinculadoId: '',
      feePercent: 0, impostoPercent: 0, bvPercent: 0, subtotalServico: 0, feeValor: 0, impostosValor: 0,
      totalSobra: 0, percentSobra: 0, somaReceita: 0, totalRentabilidade: 0, rentabilidadePercent: 0,
      // custosOperacionais/fundoDeprec/lucroLiquido nascem zerados — recalculados sozinhos assim que
      // alguém da equipe abrir e salvar este orçamento dentro do app (_calcQuebraOrcamento() no HTML).
      impostoNfPct: impostoNfPct, impostoNfValor: Math.round(impostoNfValor * 100) / 100,
