// V2.68 — 10/07/2026 16:20 — BUGFIX: os 3 formulários públicos (Clientes/Fornecedores/NPS) mandam o
// nome ANTIGO da aba (ex: "DB_Clientes"), renomeada pra "Clientes" desde a V120 (ver
// SHEET_LEGACY_NAMES). Sem esse fallback, getSheetByName(sheetName) retornava null e o insertRow
// lançava erro — como os formulários usam fetch com mode:"no-cors", o erro nunca aparecia pro
// preenchedor (a tela de sucesso aparecia igual), então os cadastros podem ter parado de cair na
// planilha silenciosamente. Agora aceita tanto o nome novo quanto o antigo.
function insertRow(rowData, sheetName) {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sheet = ss.getSheetByName(sheetName);
  if (!sheet) {
    var nomeNovo = null;
    for (var novo in SHEET_LEGACY_NAMES) { if (SHEET_LEGACY_NAMES[novo] === sheetName) { nomeNovo = novo; break; } }
    if (nomeNovo) sheet = ss.getSheetByName(nomeNovo);
  }
  if (!sheet) throw new Error('Aba "' + sheetName + '" não encontrada');
  var headers = sheet.getRange(1, 1, 1, sheet.getLastColumn()).getValues()[0];
  var row = headers.map(function(header) {
    if (!header) return '';
    var value = rowData[header];
    return (value === undefined || value === null || value === '') ? '' : value;
  });
  sheet.appendRow(row);
  return { success: true, message: 'Registro inserido em ' + sheetName, id: rowData.id };
}

