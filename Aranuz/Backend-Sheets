   cobre a maior parte do pedido de "remetente configurável" na prática (quem recebe vê o nome da empresa,
   não "aranuzworkspace@gmail.com"). */
// Helper único de envio, usado pelos 3 recursos acima — nunca lança erro pra fora.
function _enviarEmailApp_(destinatarios, remetenteNome, assunto, corpoHtml, anexos) {
  try {
    var lista = String(destinatarios || '').split(/[,;]/).map(function(s){ return s.trim(); }).filter(function(s){ return s; });
    if (!lista.length) return { status: 'erro', detalhe: 'Nenhum destinatário informado.' };
    var opcoes = {
      to: lista.join(','),
      subject: assunto || 'Aranuz',
      htmlBody: corpoHtml || '',
      name: (remetenteNome || 'Aranuz')
    };
    if (anexos && anexos.length) opcoes.attachments = anexos;
    MailApp.sendEmail(opcoes);
    return { status: 'sucesso' };
  } catch (e) {
    logErro('_enviarEmailApp_', e);
    return { status: 'erro', detalhe: e.toString() };
  }
}
// V3.17 — instala/remove os 2 gatilhos semanais de acordo com os toggles salvos em Configurações
