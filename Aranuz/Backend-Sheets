// V2.73 — 10/07/2026 21:00: RECAPTCHA_SECRET_KEY — cole aqui a Secret Key gerada em
// https://www.google.com/recaptcha/admin (escolha reCAPTCHA v3, MESMO domínio/site cadastrado com a
// Site Key usada no formularioContatoSite.html). Enquanto ficar com o valor de exemplo abaixo, o
// formulário de Contato do site recusa TODOS os envios com segurança (nunca grava metade dos dados).
var RECAPTCHA_SECRET_KEY = 'COLE_AQUI_SUA_SECRET_KEY';
var RECAPTCHA_SCORE_MINIMO = 0.5; // 0 (parece bot) a 1 (parece humano) — 0.5 é o padrão recomendado pelo Google
// Confere o token de reCAPTCHA v3 recebido do formulário direto com o Google (siteverify) — nunca confia
// só no que o navegador de quem preencheu disse. Retorna false (e nunca lança erro) pra qualquer
// situação que não seja "aprovado com confiança": token ausente, chave não configurada, erro de rede, ou
// pontuação de confiança abaixo do mínimo.
function _verificarRecaptcha_(token) {
  if (!token) return false;
  if (!RECAPTCHA_SECRET_KEY || RECAPTCHA_SECRET_KEY.indexOf('COLE_AQUI') === 0) {
    logErro('_verificarRecaptcha_', new Error('RECAPTCHA_SECRET_KEY não configurada no .gs — veja o comentário acima desta função.'));
    return false;
  }
  try {
    var resp = UrlFetchApp.fetch('https://www.google.com/recaptcha/api/siteverify', {
      method: 'post',
      payload: { secret: RECAPTCHA_SECRET_KEY, response: token },
      muteHttpExceptions: true
    });
    var resultado = JSON.parse(resp.getContentText());
    return !!(resultado.success && (typeof resultado.score !== 'number' || resultado.score >= RECAPTCHA_SCORE_MINIMO));
  } catch (e) {
    logErro('_verificarRecaptcha_', e);
    return false;
  }
}
// Recebe os dados do formulário público de Contato do site e entra como um LEAD NOVO em "Leads e
// Oportunidades" — mesmo formato de um lead criado manualmente dentro do app (ver saveLead() no HTML) ou
// pelo Radar (ver buscarRadar()), reaproveitando _appendOportunidades_() (adiciona só a linha nova, sem
// reler/reescrever a aba inteira) dentro do mesmo LockService usado por doPost()/buscarRadar(). Nasce na
// etapa "No Radar" (stage 0) com Origem do Lead = "Site" — o Aranuz já tem um Alerta Automático do
// Sistema pronto pra avisar disso ("Novo lead com origem site").
function inserirContatoSite_(dadosRecebidos) {
  try {
    var dados = dadosRecebidos || {};
    if (!_verificarRecaptcha_(dados.recaptchaToken)) {
      return { success: false, message: 'Não foi possível validar o formulário. Tente novamente.' };
    }
    var nome = String(dados.nome || '').trim();
    var email = String(dados.email || '').trim();
    var telefone = String(dados.telefone || '').trim();
    var mensagem = String(dados.mensagem || '').trim();
    if (!nome || !email || !mensagem) {
      return { success: false, message: 'Nome, e-mail e mensagem são obrigatórios.' };
    }
    var novoLead = {
      id: Date.now(), dateIn: dataHojeBR(), company: String(dados.empresa || '').trim() || nome,
      segment: '', city: '', state: 'ES', clientType: 'Cliente Final', stage: 0, nextAction: '',
      companyPhone: telefone, site: '', instagram: '', linkedin: '',
      score: { mkt: 0, fin: 0, align: 0, manual: null },
      decisor: { nome: nome, cargo: '', tel: telefone, email: email, linkedin: '' },
      influenciador: { nome: '', cargo: '', tel: '', email: '', linkedin: '' },
      dores: '', gatilho: '', maturidade: '', pitch: '',
      history: [{ date: new Date().toLocaleString('pt-BR'), text: 'Mensagem recebida pelo formulário de contato do site: "' + mensagem + '"' }],
      origem: 'site', origemCanal: 'Site', qualification: 'pendente', updatedAt: Date.now()
    };
    var lock = LockService.getScriptLock();
    var lockOk = true;
    try { lock.waitLock(25000); } catch (lockErr) { lockOk = false; logErro('inserirContatoSite_lock', lockErr); }
    try { _appendOportunidades_([novoLead]); } finally { if (lockOk) { try { lock.releaseLock(); } catch (releaseErr) {} } }
    espelharFormularioPublicoNoFirestore_('leads', novoLead);
    // V2.83 — 11/07/2026 17:40: além de entrar como Lead, avisa por e-mail (pro endereço configurado em
    // Configurações da Empresa > E-mail) assim que alguém preenche o formulário de Contato do site — não
    // depende de ninguém estar com o app aberto pra saber que chegou uma mensagem nova.
    _notificarNovoContatoSite_(nome, email, telefone, mensagem, novoLead.company);
    return { success: true, message: 'Contato recebido com sucesso.' };
  } catch (e) {
    logErro('inserirContatoSite_', e);
    return { success: false, message: 'Erro no servidor.' };
  }
}
// Envia um e-mail avisando sobre um novo contato recebido pelo formulário público do site — pro endereço
// em Configurações da Empresa > E-mail (obterConfigValor_('emailEmpresa')). Nunca lança erro pra fora: se
