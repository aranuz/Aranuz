// V235: quando preenchida (só durante importarDadosDeBackup_(), sempre dentro de um try/finally que
// garante voltar pra null mesmo se algo falhar no meio do caminho), toda leitura/gravação que passa por
// obterAba() usa essa planilha (a CÓPIA TEMPORÁRIA da origem da importação) em vez da planilha ativa do
// app. É o único ponto de mudança pra fazer os ~20 leitores/gravadores existentes (lerOportunidades,
// lerProjetos, gravarFinanceiro etc.) funcionarem também durante uma importação, sem alterar nada neles.
var IMPORT_ORIGEM_SS_ = null;

function obterAba(nome, colunas) {
  const ss = IMPORT_ORIGEM_SS_ || SpreadsheetApp.getActiveSpreadsheet();
  let aba = ss.getSheetByName(nome);
  if (!aba && SHEET_LEGACY_NAMES[nome]) {
    // V120: migra a aba do nome técnico antigo (ex.: "DB_Clientes") para o nome social novo
    // (ex.: "Clientes"), preservando 100% dos dados já gravados — só renomeia, não recria.
    const abaAntiga = ss.getSheetByName(SHEET_LEGACY_NAMES[nome]);
    if (abaAntiga) { abaAntiga.setName(nome); aba = abaAntiga; }
  }
  if (!aba) { 
    aba = ss.insertSheet(nome); 
    aba.getRange(1,1,1,colunas.length).setValues([colunas]).setFontWeight("bold").setBackground("#f3f3f3"); 
    return aba;
  }
  const ultimaColuna = aba.getLastColumn();
  if (ultimaColuna === 0) {
    aba.getRange(1,1,1,colunas.length).setValues([colunas]).setFontWeight("bold").setBackground("#f3f3f3");
    return aba;
  }
  var hdr = aba.getRange(1,1,1,ultimaColuna).getValues()[0];
  colunas.forEach(function(col) {
    if (hdr.indexOf(col) === -1) {
      var newCol = aba.getLastColumn() + 1;
      aba.getRange(1, newCol).setValue(col).setFontWeight("bold").setBackground("#f3f3f3");
      hdr.push(col);
    }
  });
  return aba;
}

